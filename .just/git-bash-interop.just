# Auto-generated by celestia-devtools init. Sets the interpreter for
# empty-[script] recipes (those without an explicit interpreter arg).
# Pins them to the resolved Git Bash (C:/Program Files/Git/usr/bin/bash.exe) so it survives WSL PATH shadowing.
# Re-run `celestia-devtools init` after moving Git or changing PATH.
set script-interpreter := ["C:/Program Files/Git/usr/bin/bash.exe", "-eu"]
